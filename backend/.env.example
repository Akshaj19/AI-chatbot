# ============================================================
#  Pick ONE provider below, copy this file to ".env",
#  fill in your API_KEY, and you're done.
# ============================================================

# ---- OPTION 1: Groq (FREE + super fast) --- RECOMMENDED TO START ----
BASE_URL=https://api.groq.com/openai/v1
API_KEY=your_groq_key_here
MODEL=llama-3.3-70b-versatile

# ---- OPTION 2: Google Gemini (FREE, very smart) ----
# BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# API_KEY=your_gemini_key_here
# MODEL=gemini-2.5-flash

# ---- OPTION 3: OpenRouter (many models, some free) ----
# BASE_URL=https://openrouter.ai/api/v1
# API_KEY=your_openrouter_key_here
# MODEL=meta-llama/llama-3.3-70b-instruct

# ---- OPTION 4: Local Ollama (100% offline, no key needed) ----
# BASE_URL=http://localhost:11434/v1
# API_KEY=
# MODEL=qwen2.5-coder:7b

# ---- Give your bot a personality / instructions ----
SYSTEM_PROMPT=You are MyChat, a helpful, friendly and precise AI assistant. Answer clearly and use code blocks when sharing code.
